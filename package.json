{
  "name": "@joseftmson/notion-sync",
  "version": "1.1.0",
  "type": "commonjs",
  "description": "Daily Codex and terminal log sync to Notion with encrypted local state.",
  "author": "Josef",
  "license": "MIT",
  "homepage": "https://github.com/jozrftamson/notion-sync",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jozrftamson/notion-sync.git"
  },
  "bugs": {
    "url": "https://github.com/jozrftamson/notion-sync/issues"
  },
  "files": [
    "daily-upload.js",
    "README.md",
    "CHANGELOG.md",
    ".env.example",
    "LICENSE"
  ],
  "keywords": [
    "notion",
    "cli",
    "terminal",
    "logs",
    "codex"
  ],
  "bin": {
    "notion-sync": "daily-upload.js"
  },
  "scripts": {
    "test": "node tests/cli.test.js",
    "export:codex": "node daily-upload.js export-codex",
    "export:codex-latest": "node daily-upload.js export-codex-latest",
    "help": "node daily-upload.js --help",
    "init": "node daily-upload.js --init",
    "doctor": "node daily-upload.js --doctor",
    "run": "node daily-upload.js",
    "dry-run": "node daily-upload.js --dry-run",
    "status": "node daily-upload.js --status",
    "report": "node daily-upload.js --report",
    "open": "node daily-upload.js --open",
    "remote": "node daily-upload.js --remote"
  }
}
